{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install --omit=dev",
  "framework": null,
  "redirects": [
    { "source": "/guide", "destination": "/", "permanent": false },
    { "source": "/guide/(.*)", "destination": "/", "permanent": false },
    { "source": "/assets/bali-investment-guide-2026.pdf", "destination": "/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, s-maxage=60" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, s-maxage=60" }
      ]
    }
  ]
}
